FROM node:20-bookworm-slim

WORKDIR /app

# ติดตั้ง OpenSSL ที่ Prisma ต้องการ
RUN apt-get update && apt-get install -y openssl libssl-dev && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY . .

# เพิ่มบรรทัดนี้เพื่อบังคับให้ Prisma สร้างไฟล์ใหม่สำหรับระบบ Debian
RUN npx prisma generate

EXPOSE 5000
CMD ["npm", "start"]