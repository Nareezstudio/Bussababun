FROM node:20-bookworm-slim

WORKDIR /app

# ติดตั้ง OpenSSL ที่ Prisma ต้องการอย่างเจาะจง
RUN apt-get update && apt-get install -y openssl libssl-dev && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm install

COPY . .

# บรรทัดนี้จะผ่านแน่นอนเพราะมี OpenSSL ในเครื่องแล้ว
RUN npx prisma generate

EXPOSE 5000
CMD ["npm", "start"]