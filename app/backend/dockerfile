# ใช้ Debian-based image แทน Alpine เพราะมี library ครบกว่าสำหรับ Prisma
FROM node:20-bookworm-slim

WORKDIR /app

# ติดตั้ง openssl และ library ที่จำเป็น (หัวใจสำคัญที่ทำให้ build ผ่าน)
RUN apt-get update && apt-get install -y \
    openssl \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

RUN npm install

COPY . .

# ตอนนี้ npx prisma generate จะรันผ่านแล้วเพราะมี library ครบ
RUN npx prisma generate

EXPOSE 5000

CMD ["npm", "start"]